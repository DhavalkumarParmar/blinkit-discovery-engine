# ── LLM providers ────────────────────────────────────────────────
# Primary provider: "groq" or "gemini"
LLM_PROVIDER=groq

# Groq (https://console.groq.com/keys) — OpenAI-compatible API, generous free tier
GROQ_API_KEY=your-groq-key-here
# Leave blank to auto-pick a verified Llama model from the live /models endpoint
GROQ_MODEL=

# Gemini fallback (https://aistudio.google.com/apikey) — uses the google-genai SDK
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── Scrapers ─────────────────────────────────────────────────────
# YouTube Data API v3 key (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=your-youtube-key-here

# ── Streamlit admin tab ──────────────────────────────────────────
ADMIN_PASSWORD=blinkit2026
