# ── LLM providers ────────────────────────────────────────────────
# Primary provider: "groq" or "gemini"
LLM_PROVIDER=groq

# Groq (https://console.groq.com/keys) — OpenAI-compatible API.
# NOTE: the free tier is capped at ~100,000 TOKENS PER DAY (TPD) for
# llama-3.3-70b-versatile — enough for ~250 tagged items/day. The client detects
# this daily 429 and fails over to Gemini immediately (no wasted retries). The
# tagger is resumable, so large datasets can be tagged across multiple days.
GROQ_API_KEY=your-groq-key-here
# Leave blank to auto-pick a verified Llama model from the live /models endpoint
GROQ_MODEL=

# Gemini fallback (https://aistudio.google.com/apikey) — uses the google-genai SDK
GEMINI_API_KEY=your-gemini-key-here
# Verified live 2026-07: gemini-2.0-flash has NO free-tier quota anymore ("limit: 0");
# gemini-3.6-flash works on the free tier.
GEMINI_MODEL=gemini-3.6-flash

# ── Scrapers ─────────────────────────────────────────────────────
# YouTube Data API v3 key (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=your-youtube-key-here

# ── Streamlit admin tab ──────────────────────────────────────────
ADMIN_PASSWORD=blinkit2026
